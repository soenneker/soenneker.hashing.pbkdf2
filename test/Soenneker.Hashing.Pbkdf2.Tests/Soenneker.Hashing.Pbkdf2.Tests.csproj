<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <IsPackable>false</IsPackable>
    </PropertyGroup>

    <ItemGroup>
        <None Remove="appsettings.json" />
    </ItemGroup>

    <ItemGroup>
        <Content Include="appsettings.json">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Soenneker.Utils.Test" Version="4.0.320" />
        <PackageReference Include="Soenneker.Tests.HostedUnit" Version="4.0.101" />
        <PackageReference Include="TUnit" Version="1.56.25" />
        <PackageReference Include="Soenneker.Tests.Benchmark" Version="4.0.120" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\src\Soenneker.Hashing.Pbkdf2\Soenneker.Hashing.Pbkdf2.csproj" />
    </ItemGroup>
  <ItemGroup>
    <Compile Remove="**/Benchmarks/**/*.cs" />
    <Compile Remove="**/Benchmarking/**/*.cs" />
  </ItemGroup>
</Project>



